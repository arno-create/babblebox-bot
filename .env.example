DISCORD_TOKEN=your_bot_token_here
DEV_GUILD_ID=your_test_server_id_here
# Preferred durable utility storage:
# UTILITY_DATABASE_URL=postgresql://user:password@host:5432/database
# Alternate Postgres env names also supported:
# SUPABASE_DB_URL=postgresql://user:password@host:5432/database
# DATABASE_URL=postgresql://user:password@host:5432/database
# Required for Postgres-backed Confessions privacy hardening:
# CONFESSIONS_CONTENT_KEY=replace-with-a-random-secret-at-least-32-characters
# CONFESSIONS_IDENTITY_KEY=replace-with-a-second-random-secret-at-least-32-characters
# Optional but recommended active key labels for Confessions key rotation:
# CONFESSIONS_CONTENT_KEY_ID=active
# CONFESSIONS_IDENTITY_KEY_ID=active
# Optional only during Confessions key rotation or compatibility windows:
# CONFESSIONS_CONTENT_LEGACY_KEYS=prior=replace-with-the-previous-content-secret
# CONFESSIONS_IDENTITY_LEGACY_KEYS=prior=replace-with-the-previous-identity-secret
# Existing Postgres-backed Confessions deployments still need the staged privacy backfill after keys are set:
# python -m babblebox.confessions_backfill --dry-run
# python -m babblebox.confessions_backfill --apply --batch-size 100
# Optional Shield AI second-pass review:
# OPENAI_API_KEY=sk-...
# SHIELD_AI_FAST_MODEL=gpt-5.4-nano
# SHIELD_AI_COMPLEX_MODEL=gpt-5.4-mini
# SHIELD_AI_TOP_MODEL=gpt-5.4
# SHIELD_AI_ENABLE_TOP_TIER=false
# SHIELD_AI_MODEL=
# SHIELD_AI_TIMEOUT_SECONDS=4
# SHIELD_AI_MAX_CHARS=340
# Explicit local/test-only memory mode:
# UTILITY_STORAGE_BACKEND=memory
# ADMIN_STORAGE_BACKEND=memory
# SHIELD_STORAGE_BACKEND=memory
# PROFILE_STORAGE_BACKEND=memory
# Optional one-time legacy import source:
# UTILITY_JSON_MIGRATION_PATH=.cache/utility_state.json
# UTILITY_JSON_PATH=.cache/utility_state.json
