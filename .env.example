DISCORD_TOKEN=your_bot_token_here
DEV_GUILD_ID=your_test_server_id_here
# Recommended for faster slash sync verification before global propagation.
# Preferred durable utility storage:
# UTILITY_DATABASE_URL=postgresql://user:password@host:5432/database
# Alternate Postgres env names also supported:
# SUPABASE_DB_URL=postgresql://user:password@host:5432/database
# DATABASE_URL=postgresql://user:password@host:5432/database
# Required for Postgres-backed Confessions privacy hardening:
# CONFESSIONS_CONTENT_KEY=replace-with-a-random-secret-at-least-32-characters
# CONFESSIONS_IDENTITY_KEY=replace-with-a-second-random-secret-at-least-32-characters
# Optional but recommended active key labels for Confessions key rotation:
# CONFESSIONS_CONTENT_KEY_ID=active
# CONFESSIONS_IDENTITY_KEY_ID=active
# Optional only during Confessions key rotation or compatibility windows:
# CONFESSIONS_CONTENT_LEGACY_KEYS=prior=replace-with-the-previous-content-secret
# CONFESSIONS_IDENTITY_LEGACY_KEYS=prior=replace-with-the-previous-identity-secret
# Existing Postgres-backed Confessions deployments still need the staged privacy backfill after keys are set:
# python -m babblebox.confessions_backfill --dry-run
# python -m babblebox.confessions_backfill --apply --batch-size 100
# Premium entitlements and Patreon linking:
# PREMIUM_STORAGE_BACKEND=postgres
# PREMIUM_DATABASE_URL=postgresql://user:password@host:5432/database
# PREMIUM_SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
# PREMIUM_SECRET_KEY_ID=active
# PREMIUM_SECRET_LEGACY_KEYS=prior=replace-with-the-previous-premium-secret
# PUBLIC_BASE_URL=https://your-public-babblebox-domain.example
# Optional embedded web bind override. Defaults to 127.0.0.1 and only auto-binds 0.0.0.0 when PUBLIC_BASE_URL is set:
# BABBLEBOX_WEB_HOST=127.0.0.1
# Optional comma-separated public hostnames accepted by the embedded web surface in addition to PUBLIC_BASE_URL and loopback:
# BABBLEBOX_TRUSTED_HOSTS=your-public-babblebox-domain.example,your-render-service.onrender.com
# The embedded HTTP surface uses in-process Waitress. Keep it behind external TLS and reverse proxying in production.
# Babblebox caps embedded HTTP request bodies at 64 KiB, clears untrusted proxy headers, and serves hosted HTML with a Content Security Policy.
# /livez is liveness only, /health is the public-safe summary, and /readyz is the rollout + alert gate.
# Confessions readiness stays degraded until the privacy backfill is complete and enabled guilds have safe private review plus appeals/report channels.
# Babblebox fails Patreon linking/webhooks closed if this block is incomplete or inconsistent.
# PATREON_CLIENT_ID=your_patreon_client_id
# PATREON_CLIENT_SECRET=your_patreon_client_secret
# PATREON_REDIRECT_URI must exactly match PUBLIC_BASE_URL + /premium/patreon/callback
# PATREON_REDIRECT_URI=https://your-public-babblebox-domain.example/premium/patreon/callback
# PATREON_WEBHOOK_SECRET=your_patreon_webhook_secret
# PATREON_CAMPAIGN_ID=your_patreon_campaign_id
# Tier ID lists must be disjoint numeric Patreon tier IDs.
# PATREON_SUPPORTER_TIER_IDS=123456,234567
# PATREON_PLUS_TIER_IDS=345678
# PATREON_GUILD_PRO_TIER_IDS=456789
# Optional Top.gg vote bonus lane:
# TOPGG_ENABLED=false
# Set TOPGG_ENABLED=true only on deployments where the Top.gg webhook lane should be live.
# TOPGG_STORAGE_BACKEND=postgres
# TOPGG_TOKEN=your_topgg_api_token
# TOPGG_WEBHOOK_SECRET=whs_your_topgg_v2_webhook_secret
# TOPGG_PROJECT_ID=1480903089518022739
# If Top.gg only shows Legacy Webhooks in your dashboard, set TOPGG_WEBHOOK_SECRET to that Authorization value instead.
# V2 whs_ secrets are preferred. Legacy webhooks still work, but they also require TOPGG_TOKEN so Babblebox can confirm the vote through the legacy API.
# Legacy Top.gg does not return exact expiry timestamps, so Babblebox transparently uses the standard 12-hour vote cadence in legacy mode.
# TOPGG_TOKEN is optional in V2 mode unless you want /vote refresh recovery against the Top.gg API.
# Optional Shield AI second-pass review:
# OPENAI_API_KEY=sk-...
# SHIELD_AI_FAST_MODEL=gpt-5.4-nano
# SHIELD_AI_COMPLEX_MODEL=gpt-5.4-mini
# SHIELD_AI_TOP_MODEL=gpt-5.4
# SHIELD_AI_ENABLE_TOP_TIER=false
# SHIELD_AI_MODEL=
# SHIELD_AI_TIMEOUT_SECONDS=4
# SHIELD_AI_MAX_CHARS=340
# Explicit local/test-only memory mode:
# The embedded public web surface serves only /, /help.html, /privacy.html, /terms.html, /sitemap.xml, and /assets/...
# UTILITY_STORAGE_BACKEND=memory
# ADMIN_STORAGE_BACKEND=memory
# SHIELD_STORAGE_BACKEND=memory
# PREMIUM_STORAGE_BACKEND=memory
# TOPGG_STORAGE_BACKEND=memory
# PROFILE_STORAGE_BACKEND=memory
# Optional one-time legacy import source:
# UTILITY_JSON_MIGRATION_PATH=.cache/utility_state.json
# UTILITY_JSON_PATH=.cache/utility_state.json
